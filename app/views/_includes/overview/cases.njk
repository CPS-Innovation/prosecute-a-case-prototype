{% set anyCasesNeedAction = triageCaseCount or prosecutorNeededCaseCount or chargingDecisionNeededCaseCount or firstHearingPreparationNeededCaseCount or firstHearingOutcomeNeededCaseCount or ptphNeededCaseCount or ptphOutcomeNeededCaseCount or trialPreparationNeededCaseCount or trialOutcomeNeededCaseCount or sentenceNeededCaseCount %}

{% if anyCasesNeedAction %}
  <div class="app-overview-section">
    {# <h2 class="govuk-heading-m">Cases</h2> #}
    <ul class="govuk-list govuk-list--bulle">
      {% if triageCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/triage" class="govuk-link--no-visited-state">
            {{ triageCaseCount }} {{ triageCaseCount | pluralize("case needs", "cases need") }} triage
          </a>
        </li>
      {% endif %}
      {% if prosecutorNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/prosecutor-needed" class="govuk-link--no-visited-state">
            {{ prosecutorNeededCaseCount }} {{ prosecutorNeededCaseCount | pluralize("case needs", "cases need") }} a prosecution team assigned
          </a>
        </li>
      {% endif %}
      {% if chargingDecisionNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/charging-decision-needed" class="govuk-link--no-visited-state">
            {{ chargingDecisionNeededCaseCount }} {{ chargingDecisionNeededCaseCount | pluralize("case needs", "cases need") }} a charging decision
          </a>
        </li>
      {% endif %}
      {% if firstHearingPreparationNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/first-hearing-preparation-needed" class="govuk-link--no-visited-state">
            {{ firstHearingPreparationNeededCaseCount }} {{ firstHearingPreparationNeededCaseCount | pluralize("case needs", "cases need") }} first hearing preparation
          </a>
        </li>
      {% endif %}
      {% if firstHearingOutcomeNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/first-hearing-outcome-needed" class="govuk-link--no-visited-state">
            {{ firstHearingOutcomeNeededCaseCount }} {{ firstHearingOutcomeNeededCaseCount | pluralize("case needs", "cases need") }} a first hearing outcome recorded
          </a>
        </li>
      {% endif %}
      {% if ptphNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/ptph-needed" class="govuk-link--no-visited-state">
            {{ ptphNeededCaseCount }} {{ ptphNeededCaseCount | pluralize("case needs", "cases need") }} PTPH preparation
          </a>
        </li>
      {% endif %}
      {% if ptphOutcomeNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/ptph-outcome-needed" class="govuk-link--no-visited-state">
            {{ ptphOutcomeNeededCaseCount }} {{ ptphOutcomeNeededCaseCount | pluralize("case needs", "cases need") }} a PTPH outcome recorded
          </a>
        </li>
      {% endif %}
      {% if trialPreparationNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/trial-preparation-needed" class="govuk-link--no-visited-state">
            {{ trialPreparationNeededCaseCount }} {{ trialPreparationNeededCaseCount | pluralize("case needs", "cases need") }} trial preparation
          </a>
        </li>
      {% endif %}
      {% if trialOutcomeNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/trial-outcome-needed" class="govuk-link--no-visited-state">
            {{ trialOutcomeNeededCaseCount }} {{ trialOutcomeNeededCaseCount | pluralize("case needs", "cases need") }} a trial outcome recorded
          </a>
        </li>
      {% endif %}
      {% if sentenceNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/sentence-needed" class="govuk-link--no-visited-state">
            {{ sentenceNeededCaseCount }} {{ sentenceNeededCaseCount | pluralize("case needs", "cases need") }} a sentence recorded
          </a>
        </li>
      {% endif %}
    </ul>
  </div>
{% endif %}
