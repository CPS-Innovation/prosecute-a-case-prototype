{% set anyCasesNeedAction = triageCaseCount or chargingDecisionNeededCaseCount or chargedCaseCount or magsNeedsProsecutorCount or crownNeedsProsecutorCount or crownNeedsParalegalOfficerCount %}

{% if anyCasesNeedAction %}
  <div class="app-overview-section">
    {# <h2 class="govuk-heading-m">Cases</h2> #}
    <ul class="govuk-list govuk-list--bulle">
      {% if triageCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/triage" class="govuk-link--no-visited-state">
            {{ triageCaseCount }} {{ triageCaseCount | pluralize("case needs", "cases need") }} triage
          </a>
        </li>
      {% endif %}
      {% if chargingDecisionNeededCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/charging-decision-needed" class="govuk-link--no-visited-state">
            {{ chargingDecisionNeededCaseCount }} {{ chargingDecisionNeededCaseCount | pluralize("case needs", "cases need") }} a charging decision
          </a>
        </li>
      {% endif %}
      {% if chargedCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/charged" class="govuk-link--no-visited-state">
            {{ chargedCaseCount }} {{ chargedCaseCount | pluralize("case is", "cases are") }} charged
          </a>
        </li>
      {% endif %}
      {% if magsNeedsProsecutorCount > 0 %}
        <li>
          <a href="/cases/shortcut/mags-needs-prosecutor" class="govuk-link--no-visited-state">
            {{ magsNeedsProsecutorCount }} magistrates {{ magsNeedsProsecutorCount | pluralize("case needs", "cases need") }} a prosecutor
          </a>
        </li>
      {% endif %}
      {% if crownNeedsProsecutorCount > 0 %}
        <li>
          <a href="/cases/shortcut/crown-needs-prosecutor" class="govuk-link--no-visited-state">
            {{ crownNeedsProsecutorCount }} crown court {{ crownNeedsProsecutorCount | pluralize("case needs", "cases need") }} a prosecutor
          </a>
        </li>
      {% endif %}
      {% if crownNeedsParalegalOfficerCount > 0 %}
        <li>
          <a href="/cases/shortcut/crown-needs-paralegal-officer" class="govuk-link--no-visited-state">
            {{ crownNeedsParalegalOfficerCount }} crown court {{ crownNeedsParalegalOfficerCount | pluralize("case needs", "cases need") }} a paralegal officer
          </a>
        </li>
      {% endif %}
    </ul>
  </div>
{% endif %}
