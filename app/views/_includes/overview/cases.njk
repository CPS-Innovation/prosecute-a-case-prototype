
{% if unassignedCaseCount > 0 %}
  <div class="app-overview-section">
    <h2 class="govuk-heading-m">Cases</h2>
    <ul class="govuk-list govuk-list--bullet">
      {% if unassignedCaseCount > 0 %}
        <li>
          <a href="/cases/shortcut/unassigned" class="govuk-link--no-visited-state">
            {{unassignedCaseCount}} {{ unassignedCaseCount | pluralize("case does not", "cases do not") }}
            have a prosecutor assigned
          </a>
        </li>
      {% endif %}
    </ul>
  </div>
{% endif %}


