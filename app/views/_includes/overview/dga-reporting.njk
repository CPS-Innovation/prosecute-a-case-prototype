{% if latestDGAMonth %}
  <div class="app-overview-section">
    <h2 class="govuk-heading-m">DGA reporting</h2>
    <ul class="govuk-list govuk-list--bullet">
      <li>
        <a href="/dga-reporting/{{ latestDGAMonth.key }}" class="govuk-link--no-visited-state">
          {{ latestDGAMonth.count }}
          {% if latestDGAMonth.count == 1 %}
            case needs
          {% else %}
            cases need
          {% endif %}
          DGA dispute outcomes recorded by {{ latestDGAMonth.deadline | isoDateString | govukDate }}
        </a>
      </li>
    </ul>
  </div>
{% endif %}
