
{%- set menuButtonText = params.menuButtonText if params.menuButtonText else 'Menu' -%}

<header class="app-header" role="banner" data-module="app-header">
  <div class="app-header__container govuk-width-container">
    <div class="app-header__logo">
      <a href="{{ params.serviceUrl }}">
        <span class="govuk-!-font-weight-bold">CPS</span>
        {% if params.productName %}
          <span class="app-header__product-name">&nbsp;{{ params.productName }}</span>
        {% endif %}
      </a>
    </div>
    {% if params.navigation %}
      <div class="app-header__content">
        <nav aria-label="{{ params.navigationLabel | default(menuButtonText) }}" class="app-header__navigation">
          <button type="button" class="app-header__menu-button govuk-js-header-toggle" aria-controls="navigation" aria-label="{{ params.menuButtonLabel | default('Show or hide menu') }}" hidden>{{ menuButtonText }}</button>
          <ul id="navigation" class="app-header__navigation-list">
            {% for item in params.navigation %}
              {% if item.text or item.html %}
                <li class="app-header__navigation-item{{ ' app-header__navigation-item--active' if item.active }}">
                  {% if item.href %}
                    <a href="{{ item.href }}">
                  {% endif %}
                  {{ item.html | safe if item.html else item.text }}
                  {% if item.href %}
                    </a>
                  {% endif %}
                </li>
              {% endif %}
            {% endfor %}
          </ul>
        </nav>
      </div>
    {% endif %}
  </div>
</header>
