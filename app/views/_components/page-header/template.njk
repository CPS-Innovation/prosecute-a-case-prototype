<div class="app-page-header{{- ' ' + params.classes if params.classes}}" {%- for attribute, value in params.attributes %} {{ attribute }}="{{ value }}"{% endfor %}>

  <div class="app-page-header__title">
    <h{{ params.heading.level | default(1) }} class="{{ params.heading.classes | default('govuk-heading-xl') }}">
      {{- params.heading.html | safe if params.heading.html else params.heading.text -}}
    </h{{ params.heading.level | default(1) }}>
  </div>

  {% if params.items %}
    <div class="app-page-header__actions">
      {% for item in params.items %}
        <a href="{{ item.href }}" class="govuk-link app-page-header__action">{{ item.text }}</a>
      {% endfor %}
    </div>
  {% endif %}

</div>
